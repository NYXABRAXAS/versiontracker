# ============================================================================
# LOS Version Management Portal - Environment Configuration
# Copy this file to .env (root) and/or apps/api/.env for local development.
# On Render, these are set as Environment Variables per service (see render.yaml).
# ============================================================================

# ---- Database ----
# Local dev example (matches local PostgreSQL 17 instance):
DATABASE_URL="postgresql://postgres@localhost:5432/los_version_portal?schema=public"

# ---- Node / Server ----
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
# Comma separated list of origins allowed to call the API with credentials
CORS_ORIGINS=http://localhost:3000

# ---- Auth / JWT ----
# Generate strong random secrets for production, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET=change-me-access-secret-change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER_ME=30d
COOKIE_SECRET=change-me-cookie-secret-change-me-cookie-secret
CSRF_SECRET=change-me-csrf-secret-change-me-csrf-secret
# true in production (requires HTTPS)
COOKIE_SECURE=false

# ---- Password Policy Defaults (overridable by Admin > Settings) ----
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=30

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25

# ---- Backups ----
BACKUP_DIR=./backups
BACKUP_CRON="0 2 * * *"
PG_DUMP_PATH=pg_dump

# ---- SMTP / Email (overridable by Admin > Settings) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="LOS Version Portal <no-reply@example.com>"

# ---- Seed / Default Super Admin ----
SEED_SUPER_ADMIN_EMAIL=admin@company.com
SEED_SUPER_ADMIN_PASSWORD=Admin@123

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
